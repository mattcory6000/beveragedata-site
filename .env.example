# Resend API key for the /api/contact route.
# Create one at https://resend.com and set this in your hosting provider (e.g. Vercel).
RESEND_API_KEY=

# Optional: override the From address. Defaults to "Website Contact <onboarding@resend.dev>".
# Use a verified-domain sender once your domain is configured in Resend, e.g.:
# CONTACT_FROM_ADDRESS="Matt Cory <hello@beveragedata.ai>"
CONTACT_FROM_ADDRESS=
